# Connects from your host machine, not from inside Docker - use localhost, not the influxdb container name
INFLUXDB_URL=https://localhost:8086
INFLUXDB_TOKEN=change-me-too
INFLUXDB_ORG=vigilo
INFLUXDB_BUCKET=telemetry

# MQTT broker - same host-vs-container note as above
MQTT_BROKER=localhost
MQTT_PORT=1883